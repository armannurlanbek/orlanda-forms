# ─────────────────────────────────────────────────────────────────────────────
# Orlanda Forms — environment template. Copy to .env and fill in real values.
# The server REFUSES TO BOOT if required secrets are missing/placeholder/short
# (see server/src/config/env.ts). Do not commit a real .env.
# ─────────────────────────────────────────────────────────────────────────────

# --- Database -----------------------------------------------------------------
# Local docker-compose uses the bundled postgres service:
DATABASE_URL="postgresql://orlanda:orlanda@localhost:5432/orlanda_forms?schema=public"
# On the Orlanda cluster, point at the db-router instead (see deploy/CLUSTER_DEPLOY.md):
# DATABASE_URL="postgresql://orlandaforms:CHANGE_ME@127.0.0.1:6432/db_orlandaforms"

# --- Auth ---------------------------------------------------------------------
# Must be >= 32 chars and not a known placeholder. Generate: openssl rand -base64 48
JWT_SECRET="CHANGE_ME_generate_with_openssl_rand_base64_48_minimum_32_chars"
# Access token lifetime (minutes). Logout is enforced server-side via a denylist.
JWT_TTL_MINUTES="60"

# --- Anthropic (AI mapping) ---------------------------------------------------
ANTHROPIC_API_KEY="sk-ant-CHANGE_ME"
ANTHROPIC_MODEL="claude-sonnet-4-6"
# Hard ceiling on AI mapping calls per day; when reached, AI mapping is disabled.
AI_DAILY_CALL_LIMIT="500"

# --- Monday.com ---------------------------------------------------------------
MONDAY_API_TOKEN="CHANGE_ME"

# --- App ----------------------------------------------------------------------
# Public origin of the app; used for cookies, CORS, CSRF Origin allowlist.
APP_URL="http://localhost:5173"
# Port the API server listens on (cluster: pick a free port e.g. 8001).
PORT="8001"
NODE_ENV="development"

# --- Abuse / spend controls (sensible defaults; override to taste) ------------
SUBMIT_RATE_PER_MIN_PER_IP="5"
SUBMIT_RATE_PER_HOUR_PER_IP="30"
SUBMIT_RATE_GLOBAL_PER_MIN="60"
FORM_DAILY_CAP_DEFAULT="200"
LOGIN_RATE_PER_MIN="5"

# --- Privacy / retention ------------------------------------------------------
# Days to retain submissions before the scheduled purge deletes them.
SUBMISSION_RETENTION_DAYS="90"

# --- Error monitoring (optional; no-op if unset) ------------------------------
SENTRY_DSN=""

# --- Seed admin (used by `npm run seed`) --------------------------------------
ADMIN_EMAIL="admin@example.com"
# Leave blank to auto-generate a strong password (printed once on seed).
ADMIN_PASSWORD=""
